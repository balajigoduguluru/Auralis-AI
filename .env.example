# =============================================================================
# AURALIS AI — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
#   cp .env.example .env.local
#
# WARNING: Never commit `.env` or `.env.local` to version control.
#          These files contain sensitive credentials.
# =============================================================================

# --- Gemini AI API -----------------------------------------------------------
# API key for Google Gemini AI services.
# Obtain from: https://aistudio.google.com/app/apikey
#
# IMPORTANT (Vite 6):
#   - Must be prefixed with VITE_ to be available in client code.
#   - In development: Vite reads .env.local automatically.
#   - In production (Vercel/Netlify): set this in your hosting dashboard.
#   - Security: VITE_* variables are inlined into the JS bundle at build time.
#     They are VISIBLE to anyone who views the page source.
#     For production, consider proxying through a serverless function instead.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- Application URL ---------------------------------------------------------
# The public URL where this instance is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# --- Feature Flags (optional) ------------------------------------------------
# Set to "true" to enable debug logging in the browser console.
VITE_DEBUG_MODE="false"

# Set to "true" to disable HMR (useful for AI Studio deployments).
DISABLE_HMR="false"

# --- EmailJS (Observations & Feedback) ---------------------------------------
# Used to send email notifications and auto-replies when users submit observations.
# Sign up at https://www.emailjs.com/ (free tier: 200 emails/month).
# 1. Create an Email Service (e.g., Gmail) → get Service ID
# 2. Create two Email Templates:
#    a) Notification Template (VITE_EMAILJS_NOTIFICATION_TEMPLATE_ID):
#       Variables: {{to_email}}, {{from_name}}, {{user_email}}, {{message}}, {{location}}, {{timestamp}}
#       This sends you an alert when someone submits an observation.
#    b) Auto-Reply Template (VITE_EMAILJS_AUTO_REPLY_TEMPLATE_ID):
#       Variables: {{to_email}}, {{from_name}}, {{message}}, {{location}}, {{reply_message}}
#       This sends a confirmation email back to the user.
# 3. Copy your Account Public Key from the Dashboard
# IMPORTANT: VITE_* variables are inlined into the JS bundle and visible in
#            the browser. For production, consider a server-side proxy.
VITE_EMAILJS_SERVICE_ID="YOUR_SERVICE_ID_HERE"
VITE_EMAILJS_NOTIFICATION_TEMPLATE_ID="YOUR_NOTIFICATION_TEMPLATE_ID_HERE"
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID="YOUR_AUTO_REPLY_TEMPLATE_ID_HERE"
VITE_EMAILJS_PUBLIC_KEY="YOUR_PUBLIC_KEY_HERE"

# --- Admin Panel --------------------------------------------------------------
# Password to access the admin panel. Keep this secret and strong.
VITE_ADMIN_SECRET="YOUR_ADMIN_PASSWORD_HERE"
