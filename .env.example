# =============================================================================
# AURALIS AI — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
#   cp .env.example .env.local
#
# WARNING: Never commit `.env` or `.env.local` to version control.
#          These files contain sensitive credentials.
# =============================================================================

# --- Gemini AI API -----------------------------------------------------------
# API key for Google Gemini AI services.
# Obtain from: https://aistudio.google.com/app/apikey
#
# IMPORTANT (Vite 6):
#   - Must be prefixed with VITE_ to be available in client code.
#   - In development: Vite reads .env.local automatically.
#   - In production (Vercel/Netlify): set this in your hosting dashboard.
#   - Security: VITE_* variables are inlined into the JS bundle at build time.
#     They are VISIBLE to anyone who views the page source.
#     For production, consider proxying through a serverless function instead.
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# --- Application URL ---------------------------------------------------------
# The public URL where this instance is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# --- Feature Flags (optional) ------------------------------------------------
# Set to "true" to enable debug logging in the browser console.
VITE_DEBUG_MODE="false"

# Set to "true" to disable HMR (useful for AI Studio deployments).
DISABLE_HMR="false"
